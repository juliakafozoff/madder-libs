MONGO_URI=mongodb://localhost:27017/gladlibs
PORT=5000
SECRET_KEY=your_jwt_secret_here
FRONTEND_URL=http://localhost:3000

# Firebase Admin SDK (provide ONE of these)
# Option 1: JSON string of the service account
FIREBASE_SERVICE_ACCOUNT=
# Option 2: Path to the service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=

# AI Image Generation (optional - illustrations will be disabled without these)
# Anthropic API key for Claude image generation
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OpenAI API key (fallback for DALL-E 3 if Anthropic image gen fails)
OPENAI_API_KEY=your_openai_api_key_here
